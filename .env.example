# PaperQuantLab Environment Configuration

# Binance Read-Only API Keys (For simulated live market research)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Digifinex Read-Only API Keys (Alternative data source)
DIGIFINEX_API_KEY=your_digifinex_api_key_here
DIGIFINEX_SECRET_KEY=your_digifinex_secret_key_here

# Weex Read-Only API Keys (Alternative data source)
WEEX_API_KEY=your_weex_api_key_here
WEEX_SECRET_KEY=your_weex_secret_key_here

# Note: All keys are restricted to read-only access. 
# PaperQuantLab operates strictly in a simulation-only sandbox.
